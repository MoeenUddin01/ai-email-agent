{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    { "src": "/auth/gmail(/.*)?", "dest": "api/index.py" },
    { "src": "/auth/me", "dest": "api/index.py" },
    { "src": "/emails(/.*)?", "dest": "api/index.py" },
    { "src": "/drafts(/.*)?", "dest": "api/index.py" },
    { "src": "/feedback(/.*)?", "dest": "api/index.py" },
    { "src": "/knowledge(/.*)?", "dest": "api/index.py" },
    { "src": "/health(/.*)?", "dest": "api/index.py" },
    { "src": "/ping", "dest": "api/index.py" },
    { "src": "/openapi.json", "dest": "api/index.py" },
    { "src": "/docs", "dest": "api/index.py" },
    { "src": "/reply", "dest": "frontend/reply" },
    { "src": "/reply/", "dest": "frontend/reply" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
